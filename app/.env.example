# Jeśli nazwa zawiera spacje, ujmij ją w cudzysłowy: APP_NAME="Moja Restauracja"
APP_NAME=Eventownik
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=pl
APP_FALLBACK_LOCALE=pl
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

# Jeśli aplikacja działa za reverse proxy (np. nginx z SSL termination),
# ustaw ASSET_URL na publiczny adres HTTPS, a TRUSTED_PROXIES=*
ASSET_URL=
TRUSTED_PROXIES=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=eventownik
DB_USERNAME=eventownik
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# === MAIL ===
# Dev: mailpit działa na porcie 8025 (http://localhost:8025)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="rezerwacje@twojadomena.pl"
MAIL_FROM_NAME="${APP_NAME}"

# E-mail admina (powiadomienia o nowych zapytaniach)
ADMIN_EMAIL=admin@eventownik.pl
ADMIN_PASSWORD=changeme123!

# Numer konta bankowego wyświetlany w mailu potwierdzającym
PAYMENT_ACCOUNT="00 0000 0000 0000 0000 0000 0000"

# === Produkcja (SMTP zewnętrzny) ===
